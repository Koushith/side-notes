{
  "name": "second-brain",
  "version": "0.4.0",
  "description": "A friendly second brain for everyone — Obsidian-style, Notion-easy.",
  "author": {
    "name": "Koushith",
    "email": "koushith97@gmail.com"
  },
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "postinstall": "node scripts/rename-electron-dev.mjs && node scripts/copy-excalidraw-assets.mjs",
    "copy:excalidraw": "node scripts/copy-excalidraw-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json",
    "prebuild": "node scripts/copy-excalidraw-assets.mjs",
    "build": "npm run typecheck && vite build",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "package:linux": "npm run build && electron-builder --linux",
    "preview": "vite preview"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1058.0",
    "@excalidraw/excalidraw": "^0.18.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tiptap/extension-bubble-menu": "^2.27.2",
    "@tiptap/extension-code-block-lowlight": "^2.27.2",
    "@tiptap/extension-highlight": "^2.27.2",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-link": "^2.10.3",
    "@tiptap/extension-placeholder": "^2.10.3",
    "@tiptap/extension-table": "^2.27.2",
    "@tiptap/extension-table-cell": "^2.27.2",
    "@tiptap/extension-table-header": "^2.27.2",
    "@tiptap/extension-table-row": "^2.27.2",
    "@tiptap/extension-task-item": "^2.10.3",
    "@tiptap/extension-task-list": "^2.10.3",
    "@tiptap/extension-typography": "^2.27.2",
    "@tiptap/pm": "^2.10.3",
    "@tiptap/react": "^2.10.3",
    "@tiptap/starter-kit": "^2.10.3",
    "@tiptap/suggestion": "^2.27.2",
    "@xyflow/react": "^12.10.2",
    "chokidar": "^4.0.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "graphology": "^0.25.4",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-operators": "^1.6.1",
    "graphology-shortest-path": "^2.1.0",
    "gray-matter": "^4.0.3",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.468.0",
    "mermaid": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sigma": "^3.0.1",
    "simple-git": "^3.36.0",
    "tailwind-merge": "^2.5.5",
    "tippy.js": "^6.3.7",
    "tiptap-markdown": "^0.8.10",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.koushith.sidenotes",
    "productName": "SideNotes",
    "copyright": "Copyright © 2026 SideNotes",
    "artifactName": "SideNotes-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "icon": "build/icon.icns",
      "notarize": {
          "teamId": "HSNXURXG94"
        },
      "extendInfo": {
        "NSMicrophoneUsageDescription": "SideNotes uses the microphone to transcribe your speech into notes when you dictate."
      }
    },
    "mas": {
      "category": "public.app-category.productivity",
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.plist",
      "hardenedRuntime": true,
      "provisioningProfile": "build/SideNotes.provisionprofile",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "SideNotes uses the microphone to transcribe your speech into notes when you dictate."
      }
    },
    "dmg": {
      "title": "SideNotes ${version} ${arch}",
      "icon": "build/icon.icns",
      "background": "build/dmg-background.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "iconSize": 80,
      "contents": [
        {
          "x": 170,
          "y": 200,
          "type": "file"
        },
        {
          "x": 370,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "writeUpdateInfo": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "appx",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "appx": {
      "applicationId": "SideNotes",
      "displayName": "SideNotess",
      "publisherDisplayName": "Koushith",
      "identityName": "Koushith.SideNotess",
      "publisher": "CN=8906BAE8-D162-4B04-B983-C612680FDF14",
      "backgroundColor": "#15130f",
      "languages": [
        "en-US"
      ],
      "showNameOnTiles": true,
      "addAutoLaunchExtension": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "shortcutName": "SideNotes",
      "artifactName": "SideNotes-Setup-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "build/icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Koushith",
        "repo": "side-deck",
        "releaseType": "release"
      }
    ]
  }
}
