{
  "name": "sidenotes-remotion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "remotion studio",
    "render": "remotion render V030 out/v0.3.0.mp4 --codec h264 --concurrency 4",
    "render-v040": "remotion render V040 out/v0.4.0.mp4 --codec h264 --concurrency 4",
    "render-v040-cinematic": "remotion render V040Cinematic out/v0.4.0-cinematic.mp4 --codec h264 --concurrency 4",
    "render-vertical": "remotion render V030Vertical out/v0.3.0-vertical.mp4 --codec h264",
    "render-live": "remotion render V030Live out/v0.3.0-live.mp4 --codec h264 --concurrency 4",
    "render-cinematic": "remotion render V030Cinematic out/v0.3.0-cinematic.mp4 --codec h264 --concurrency 4",
    "render-cinematic-audio": "REMOTION_AUDIO=1 remotion render V030Cinematic out/v0.3.0-cinematic-music.mp4 --codec h264 --concurrency 4",
    "capture": "node_modules/.bin/playwright test capture/capture.spec.ts",
    "capture-stills": "node_modules/.bin/playwright test capture/stills.spec.ts",
    "render-shots": "node scripts/render-shots.mjs",
    "shots": "npm run capture-stills && npm run render-shots",
    "still": "remotion still V030 out/v0.3.0-frame.png --frame=0"
  },
  "dependencies": {
    "@remotion/cli": "4.0.460",
    "@remotion/bundler": "4.0.460",
    "@remotion/renderer": "4.0.460",
    "remotion": "4.0.460",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "playwright": "^1.49.0",
    "typescript": "^5.6.3"
  }
}
