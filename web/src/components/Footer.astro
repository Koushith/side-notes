---
const year = new Date().getFullYear();
---

<footer class="px-6 py-14 border-t border-rule-soft">
  <div class="mx-auto max-w-6xl flex flex-col md:flex-row items-start md:items-center gap-6">
    <a href="/" class="flex items-center gap-2.5">
      <span class="w-[26px] h-[26px] rounded-md bg-ink text-paper grid place-items-center font-serif font-semibold italic text-[15px]">S</span>
      <span class="font-serif text-[17px] font-semibold tracking-tight">Side</span>
    </a>
    <div class="font-serif text-[14px] text-ink-3 max-w-md">
      A quiet, local-first second brain. Plain markdown, on your Mac.
    </div>
    <div class="md:ml-auto flex items-center gap-5 font-mono text-[11px] uppercase tracking-[0.08em] text-ink-3">
      <a href="https://github.com/Koushith/side-deck" class="hover:text-ink">GitHub</a>
      <a href="https://github.com/Koushith/side-deck/issues" class="hover:text-ink">Issues</a>
      <a href="#faq" class="hover:text-ink">Questions</a>
    </div>
  </div>
  <div class="mx-auto max-w-6xl mt-10 pt-6 border-t border-rule-soft flex items-center justify-between font-mono text-[10.5px] uppercase tracking-[0.08em] text-ink-4">
    <span>© {year} Side · MIT</span>
    <span class="inline-flex items-center gap-1.5 text-tag normal-case font-medium">
      <span class="w-1.5 h-1.5 rounded-full bg-tag"></span>
      Saved on your Mac
    </span>
  </div>
</footer>
