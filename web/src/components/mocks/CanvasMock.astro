---
// Canvas (whiteboard) view — text + note cards on a dotted grid with smoothstep edges.
---

<div class="absolute inset-0 flex flex-col bg-paper">
  <!-- Title bar -->
  <div class="h-11 flex items-center px-4 border-b border-rule bg-paper gap-3">
    <div class="flex items-center gap-1.5">
      <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
      <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
      <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
    </div>
    <div class="flex items-center gap-1.5 text-[12px] text-ink-3 ml-3">
      <span>Canvases</span>
      <span class="text-ink-4">/</span>
      <strong class="text-ink font-medium">Q2 2026 Plan</strong>
    </div>
  </div>

  <div class="grid grid-cols-[240px_1fr] flex-1 min-h-0">
    <!-- Sidebar (compact) -->
    <aside class="bg-paper-2 border-r border-rule p-3 space-y-2 text-[12.5px] text-ink-2">
      <div class="flex items-center gap-2.5 pb-3 border-b border-rule-soft">
        <span class="w-[22px] h-[22px] rounded-md bg-ink text-paper grid place-items-center font-serif font-semibold italic text-[13px]">S</span>
        <span class="font-serif font-semibold text-[15px]">obs-test</span>
      </div>
      <ul class="space-y-0.5">
        <li class="flex items-center gap-2 px-2 py-1.5 rounded-md hover:bg-paper-3">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="4"/><path d="M12 3v2M12 19v2"/></svg>
          Today
        </li>
        <li class="flex items-center gap-2 px-2 py-1.5 rounded-md hover:bg-paper-3">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="6" cy="18" r="2.5"/><circle cx="18" cy="18" r="2.5"/><circle cx="12" cy="6" r="2.5"/><path d="m11 8-4 8M13 8l4 8M8 18h8"/></svg>
          Connections
        </li>
        <li class="flex items-center gap-2 px-2 py-1.5 rounded-md text-ink font-medium bg-paper-3">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="2"/><rect x="6" y="6" width="5" height="5" rx="0.5"/><rect x="13" y="13" width="5" height="5" rx="0.5"/></svg>
          Canvas
        </li>
      </ul>
      <div class="pt-2 font-mono text-[10px] uppercase tracking-[0.1em] text-ink-4">Canvases</div>
      <ul class="space-y-0.5">
        <li class="flex items-center gap-2 py-1 pl-7 rounded bg-accent-soft text-accent-ink font-medium">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
          Q2 2026 Plan
        </li>
      </ul>
    </aside>

    <!-- Whiteboard -->
    <div
      class="relative bg-paper-2 overflow-hidden"
      style="background-image: radial-gradient(rgba(31,29,26,0.08) 1px, transparent 1px); background-size: 20px 20px;"
    >
      <!-- Toolbar -->
      <div class="absolute top-3 left-3 flex gap-2 z-10">
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-md bg-paper/90 backdrop-blur border border-rule text-[12px] text-ink-3">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 7h16M4 12h16M4 17h10"/></svg>
          Text card
        </span>
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-md bg-paper/90 backdrop-blur border border-rule text-[12px] text-ink-3">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/><path d="M14 3v5h5"/></svg>
          Note card
          <span class="font-mono text-[10px]">+</span>
        </span>
      </div>

      <!-- Connection paths -->
      <svg class="absolute inset-0 w-full h-full pointer-events-none" preserveAspectRatio="none" viewBox="0 0 100 100">
        <path d="M 50 18 C 50 28, 26 28, 26 36" stroke="#c4623a" stroke-width="0.35" fill="none"/>
        <path d="M 50 18 C 50 28, 50 28, 50 36" stroke="#c4623a" stroke-width="0.35" fill="none"/>
        <path d="M 50 18 C 50 28, 75 28, 75 36" stroke="#c4623a" stroke-width="0.35" fill="none"/>
        <path d="M 50 50 C 50 60, 32 62, 32 70" stroke="#c4623a" stroke-width="0.35" fill="none"/>
        <path d="M 50 50 C 50 60, 50 62, 50 70" stroke="#c4623a" stroke-width="0.35" fill="none"/>
        <path d="M 32 78 C 32 82, 50 82, 50 78" stroke="#c4623a" stroke-width="0.35" fill="none"/>
      </svg>

      <!-- Goal text card (top center) -->
      <div class="absolute top-[8%] left-1/2 -translate-x-1/2 w-[34%] rounded-[10px] bg-paper-2 border border-rule shadow-md overflow-hidden">
        <div class="flex items-center justify-between px-2.5 py-1 bg-paper border-b border-rule">
          <span class="font-mono text-[9px] uppercase tracking-[0.1em] text-ink-3">Text</span>
        </div>
        <div class="p-2.5 font-serif text-[10.5px] leading-snug text-ink">
          Q2 2026 — Three big bets:<br/>
          1. Ship the Second Brain MVP<br/>
          2. Hit 50mpw running consistently<br/>
          3. Launch photography portfolio
        </div>
      </div>

      <!-- Three project file cards (middle row) -->
      <div class="absolute top-[36%] left-[8%] w-[26%] rounded-[10px] bg-paper-2 border border-rule shadow-md overflow-hidden">
        <div class="flex items-center justify-between px-2.5 py-1 bg-paper border-b border-rule">
          <div class="flex items-center gap-1.5">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4f6b8f" stroke-width="1.6"><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/></svg>
            <span class="font-serif text-[11px] font-semibold text-ink">Second Brain App</span>
          </div>
        </div>
        <div class="p-2.5 font-serif text-[10px] leading-snug text-ink-3">
          Building a Notion-easy, Obsidian-deep notes app for non-tech folks…
        </div>
      </div>
      <div class="absolute top-[36%] left-1/2 -translate-x-1/2 w-[26%] rounded-[10px] bg-paper-2 border border-rule shadow-md overflow-hidden">
        <div class="flex items-center justify-between px-2.5 py-1 bg-paper border-b border-rule">
          <div class="flex items-center gap-1.5">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4f6b8f" stroke-width="1.6"><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/></svg>
            <span class="font-serif text-[11px] font-semibold text-ink">Marathon Training</span>
          </div>
        </div>
        <div class="p-2.5 font-serif text-[10px] leading-snug text-ink-3">
          Berlin Marathon in September. 18-week Pfitzinger plan, peaks at 55 miles…
        </div>
      </div>
      <div class="absolute top-[36%] right-[8%] w-[26%] rounded-[10px] bg-paper-2 border border-rule shadow-md overflow-hidden">
        <div class="flex items-center justify-between px-2.5 py-1 bg-paper border-b border-rule">
          <div class="flex items-center gap-1.5">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4f6b8f" stroke-width="1.6"><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/></svg>
            <span class="font-serif text-[11px] font-semibold text-ink">Photography Portfolio</span>
          </div>
        </div>
        <div class="p-2.5 font-serif text-[10px] leading-snug text-ink-3">
          Personal site, launch by Q3. Themes: street, travel, portraits…
        </div>
      </div>

      <!-- Bottom row -->
      <div class="absolute top-[70%] left-[16%] w-[20%] rounded-[10px] bg-paper-2 border border-rule shadow-md overflow-hidden">
        <div class="flex items-center justify-between px-2.5 py-1 bg-paper border-b border-rule">
          <div class="flex items-center gap-1.5">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4f6b8f" stroke-width="1.6"><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/></svg>
            <span class="font-serif text-[10.5px] font-semibold text-ink">Workout Plan</span>
          </div>
        </div>
        <div class="p-2 font-serif text-[9.5px] leading-snug text-ink-3">Strength + mobility split.</div>
      </div>
      <div class="absolute top-[70%] left-1/2 -translate-x-1/2 w-[20%] rounded-[10px] bg-paper-2 border border-rule shadow-md overflow-hidden">
        <div class="flex items-center justify-between px-2.5 py-1 bg-paper border-b border-rule">
          <div class="flex items-center gap-1.5">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4f6b8f" stroke-width="1.6"><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/></svg>
            <span class="font-serif text-[10.5px] font-semibold text-ink">Sleep Routine</span>
          </div>
        </div>
        <div class="p-2 font-serif text-[9.5px] leading-snug text-ink-3">Phone airplane mode at 9:30.</div>
      </div>

      <!-- Mini-map -->
      <div class="absolute bottom-3 right-3 w-28 h-20 rounded-md bg-paper-2 border border-rule overflow-hidden">
        <svg viewBox="0 0 100 70" class="w-full h-full">
          <rect x="38" y="6" width="24" height="10" rx="1" fill="#4a463f"/>
          <rect x="6" y="26" width="20" height="10" rx="1" fill="#4f6b8f"/>
          <rect x="40" y="26" width="20" height="10" rx="1" fill="#4f6b8f"/>
          <rect x="74" y="26" width="20" height="10" rx="1" fill="#4f6b8f"/>
          <rect x="14" y="50" width="16" height="8" rx="1" fill="#4a463f"/>
          <rect x="42" y="50" width="16" height="8" rx="1" fill="#4a463f"/>
          <rect x="0" y="0" width="100" height="70" fill="rgba(247,243,236,0.45)"/>
          <rect x="20" y="14" width="60" height="42" stroke="#c4623a" stroke-width="1" fill="none"/>
        </svg>
      </div>
    </div>
  </div>
</div>
