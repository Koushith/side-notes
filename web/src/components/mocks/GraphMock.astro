---
// Connections graph view — full SVG graph with folder legend overlay.
---

<div class="absolute inset-0 flex flex-col bg-paper">
  <!-- Title bar -->
  <div class="h-11 flex items-center px-4 border-b border-rule bg-paper gap-3">
    <div class="flex items-center gap-1.5">
      <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
      <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
      <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
    </div>
    <div class="flex items-center gap-1.5 text-[12px] text-ink-3 ml-3">
      <strong class="text-ink font-medium">Connections</strong>
    </div>
    <div class="ml-auto flex items-center gap-1 text-ink-3">
      <span class="w-7 h-7 grid place-items-center rounded-md hover:bg-paper-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><path d="M3.6 9h16.8M3.6 15h16.8M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/></svg>
      </span>
    </div>
  </div>

  <div class="grid grid-cols-[240px_1fr] flex-1 min-h-0">
    <!-- Sidebar -->
    <aside class="bg-paper-2 border-r border-rule p-3 space-y-2 text-[12.5px] text-ink-2">
      <div class="flex items-center gap-2.5 pb-3 border-b border-rule-soft">
        <span class="w-[22px] h-[22px] rounded-md bg-ink text-paper grid place-items-center font-serif font-semibold italic text-[13px]">S</span>
        <span class="font-serif font-semibold text-[15px]">obs-test</span>
      </div>
      <ul class="space-y-0.5">
        <li class="flex items-center gap-2 px-2 py-1.5 rounded-md hover:bg-paper-3">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="4"/><path d="M12 3v2M12 19v2"/></svg>
          Today
        </li>
        <li class="flex items-center gap-2 px-2 py-1.5 rounded-md hover:bg-paper-3">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 4v16a2 2 0 0 0 2 2h14V2H6a2 2 0 0 0-2 2z"/></svg>
          All notes
          <span class="ml-auto font-mono text-[10px] text-ink-4">428</span>
        </li>
        <li class="flex items-center gap-2 px-2 py-1.5 rounded-md text-ink font-medium bg-paper-3">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="6" cy="18" r="2.5"/><circle cx="18" cy="18" r="2.5"/><circle cx="12" cy="6" r="2.5"/><path d="m11 8-4 8M13 8l4 8M8 18h8"/></svg>
          Connections
        </li>
        <li class="flex items-center gap-2 px-2 py-1.5 rounded-md hover:bg-paper-3">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
          Canvas
        </li>
      </ul>
    </aside>

    <!-- Graph area -->
    <div class="relative bg-paper">
      <!-- Stat pill -->
      <div class="absolute top-4 left-4 px-3 py-1.5 rounded-md bg-paper-2/80 backdrop-blur border border-rule font-mono text-[10px] uppercase tracking-[0.08em] text-ink-3">
        428 notes · 1,204 links
      </div>

      <!-- Folder legend -->
      <div class="absolute top-4 right-4 rounded-md bg-paper-2/85 backdrop-blur border border-rule px-3 py-2 text-[11px] text-ink-2 space-y-1.5">
        <div class="font-mono text-[9.5px] uppercase tracking-[0.1em] text-ink-3">Folders</div>
        <div class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-accent"></span>Resources<span class="ml-auto text-ink-4 font-mono text-[10px]">12</span></div>
        <div class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-tag"></span>Areas<span class="ml-auto text-ink-4 font-mono text-[10px]">8</span></div>
        <div class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-link"></span>Projects<span class="ml-auto text-ink-4 font-mono text-[10px]">6</span></div>
        <div class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full" style="background:#9a7530"></span>Daily<span class="ml-auto text-ink-4 font-mono text-[10px]">22</span></div>
      </div>

      <!-- The graph SVG, fills the container, slightly off-center for visual balance -->
      <svg viewBox="0 0 600 380" class="w-full h-full">
        <!-- edges -->
        <g stroke="#e0d9c8" stroke-width="0.9" fill="none">
          <line x1="300" y1="120" x2="200" y2="180"/>
          <line x1="300" y1="120" x2="380" y2="170"/>
          <line x1="300" y1="120" x2="290" y2="200"/>
          <line x1="200" y1="180" x2="155" y2="240"/>
          <line x1="200" y1="180" x2="290" y2="200"/>
          <line x1="380" y1="170" x2="290" y2="200"/>
          <line x1="380" y1="170" x2="450" y2="220"/>
          <line x1="290" y1="200" x2="240" y2="265"/>
          <line x1="290" y1="200" x2="350" y2="265"/>
          <line x1="155" y1="240" x2="120" y2="295"/>
          <line x1="155" y1="240" x2="240" y2="265"/>
          <line x1="450" y1="220" x2="490" y2="280"/>
          <line x1="240" y1="265" x2="350" y2="265"/>
          <line x1="350" y1="265" x2="425" y2="310"/>
          <line x1="490" y1="280" x2="425" y2="310"/>
          <line x1="120" y1="295" x2="200" y2="335"/>
          <line x1="240" y1="265" x2="200" y2="335"/>
          <line x1="200" y1="335" x2="305" y2="320"/>
          <line x1="305" y1="320" x2="425" y2="310"/>
          <line x1="305" y1="320" x2="350" y2="265"/>
          <line x1="380" y1="170" x2="490" y2="160"/>
          <line x1="490" y1="160" x2="490" y2="280"/>
        </g>
        <!-- nodes -->
        <g>
          <circle cx="300" cy="120" r="11" fill="#5a7b56"/>
          <text x="300" y="106" text-anchor="middle" font-family="Source Serif 4" font-size="11" fill="#1f1d1a">Atomic Habits</text>

          <circle cx="200" cy="180" r="8" fill="#c4623a"/>
          <text x="200" y="167" text-anchor="middle" font-family="Source Serif 4" font-size="10" fill="#1f1d1a">Sleep Routine</text>

          <circle cx="380" cy="170" r="9" fill="#4f6b8f"/>
          <text x="380" y="157" text-anchor="middle" font-family="Source Serif 4" font-size="10" fill="#1f1d1a">Building a Second Brain</text>

          <circle cx="290" cy="200" r="10" fill="#5a7b56"/>
          <text x="290" y="222" text-anchor="middle" font-family="Source Serif 4" font-size="10" fill="#1f1d1a">Workout Plan</text>

          <circle cx="155" cy="240" r="6" fill="#c4623a"/>
          <text x="135" y="244" text-anchor="end" font-family="Source Serif 4" font-size="9.5" fill="#4a463f">Marathon</text>

          <circle cx="450" cy="220" r="7" fill="#4f6b8f"/>
          <text x="466" y="224" text-anchor="start" font-family="Source Serif 4" font-size="9.5" fill="#4a463f">Deep Work</text>

          <circle cx="240" cy="265" r="6" fill="#9a7530"/>
          <text x="218" y="270" text-anchor="end" font-family="Source Serif 4" font-size="9" fill="#4a463f">2026-04-30</text>

          <circle cx="350" cy="265" r="6" fill="#9a7530"/>
          <text x="372" y="270" text-anchor="start" font-family="Source Serif 4" font-size="9" fill="#4a463f">2026-04-29</text>

          <circle cx="490" cy="280" r="5" fill="#4f6b8f"/>
          <circle cx="120" cy="295" r="5" fill="#a8a294"/>
          <circle cx="200" cy="335" r="6" fill="#c4623a"/>
          <text x="200" y="356" text-anchor="middle" font-family="Source Serif 4" font-size="9.5" fill="#4a463f">Nutrition Basics</text>

          <circle cx="305" cy="320" r="7" fill="#5a7b56"/>
          <text x="305" y="341" text-anchor="middle" font-family="Source Serif 4" font-size="9.5" fill="#4a463f">Budget 2026</text>

          <circle cx="425" cy="310" r="5" fill="#4f6b8f"/>
          <circle cx="490" cy="160" r="5" fill="#9a7530"/>
        </g>
      </svg>
    </div>
  </div>
</div>
