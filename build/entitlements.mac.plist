<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Entitlements for the Developer-ID-signed DMG/ZIP build (direct distribution).

  This profile enables the Hardened Runtime + JIT for V8, allows reading and
  writing user-selected files (the vault folder), and permits Apple Events so
  things like opening external URLs and the system file dialog work cleanly.

  This file is **not** the MAS profile — see `entitlements.mas.plist` for that.
-->
<plist version="1.0">
<dict>
  <!-- Electron uses V8 which JITs JavaScript. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Some native modules (chokidar's fsevents addon) load dynamically. -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- File access the user explicitly grants (open/save dialogs). -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>

  <!-- Apple Events — needed for shell.openExternal + dialog interactions. -->
  <key>com.apple.security.automation.apple-events</key>
  <true/>

  <!-- Microphone access for voice dictation (speech-to-text). -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
</dict>
</plist>
